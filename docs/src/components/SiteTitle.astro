---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/SiteTitle.astro';

const version = "0.3.0";
---

<div class="site-title-container">
	<Default {...Astro.props} />
	<sup class="version-tag">{version}</sup>
</div>

<style>
	.site-title-container {
		display: flex;
		align-items: center;
		gap: 0.35rem;
	}

	.version-tag {
		font-size: 0.625rem;
		font-weight: 700;
		padding: 0.125rem 0.375rem;
		background: var(--sl-color-accent-low);
		color: var(--sl-color-accent-high);
		border: 1px solid var(--sl-color-accent);
		border-radius: 6px;
		line-height: 1;
		vertical-align: super;
		margin-top: -0.5rem;
		letter-spacing: 0.025em;
		/* Reset the gradient from custom.css if it applies to sup */
		-webkit-text-fill-color: var(--sl-color-accent-high) !important;
		background-clip: padding-box !important;
	}

	:root[data-theme='light'] .version-tag {
		background: var(--sl-color-accent-low);
		color: var(--sl-color-accent);
		border-color: var(--sl-color-accent);
		-webkit-text-fill-color: var(--sl-color-accent) !important;
	}
</style>
